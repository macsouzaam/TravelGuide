# Variáveis de ambiente — TravelGuide
# Copie este arquivo para .env.local e preencha as chaves que desejar usar.
# Apenas o formulário no browser precisará da URL /api/itinerary — sem expor chaves ao cliente.

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=
# Opcional — padrão: gpt-4o-mini
OPENAI_MODEL=

# ── Google Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=
# Opcional — padrão: gemini-1.5-flash
GEMINI_MODEL=

# ── Cloud / Anthropic Claude (ou qualquer API OpenAI-compatible) ─
CLOUD_API_KEY=
# Opcional — padrão: https://api.anthropic.com/v1/messages
CLOUD_API_URL=
# Opcional — padrão: claude-3-5-haiku-latest
CLOUD_MODEL=
